{
  "name": "@react-clickmap/dashboard",
  "version": "0.1.0",
  "description": "Batteries-included dashboard components for react-clickmap.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "react-clickmap",
    "dashboard",
    "analytics",
    "heatmap"
  ],
  "dependencies": {
    "react-clickmap": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "scripts": {
    "build": "tsup",
    "check": "biome check src tsup.config.ts README.md",
    "check:fix": "biome check --write src tsup.config.ts README.md",
    "test": "echo 'no tests yet'",
    "test:run": "echo 'no tests yet'"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "biome": "npm:@biomejs/biome@^2.4.4",
    "react": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
