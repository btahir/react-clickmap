{
  "name": "react-clickmap",
  "version": "0.1.0",
  "description": "Privacy-first heatmaps for React. Your data, your database, zero cloud.",
  "license": "MIT",
  "homepage": "https://github.com/btahir/react-clickmap#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btahir/react-clickmap.git",
    "directory": "packages/react-clickmap"
  },
  "bugs": {
    "url": "https://github.com/btahir/react-clickmap/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/btahir"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "clickmap",
    "heatmap",
    "analytics",
    "privacy",
    "self-hosted"
  ],
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "biome check src tests scripts tsup.config.ts vitest.config.ts",
    "check:fix": "biome check --write src tests scripts tsup.config.ts vitest.config.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "knip": "knip --include files,dependencies",
    "size-limit": "size-limit",
    "validate:pkg": "publint && attw .",
    "budget": "node ./scripts/check-bundle-budget.mjs",
    "release": "pnpm run build && changeset publish"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "13 KB"
    }
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.7",
    "biome": "npm:@biomejs/biome@^2.4.4",
    "changeset": "npm:@changesets/cli@^2.29.7",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "publint": "^0.3.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.7"
  }
}
